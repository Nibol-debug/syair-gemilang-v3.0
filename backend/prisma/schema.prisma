// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model User {
  id            String  @id @default(uuid())
  username      String  @unique
  password_hash String
  role_id       String
  role          Role    @relation(fields: [role_id], references: [id])
  student_id    String? @unique
  employee_id   String? @unique

  student  Student?  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employee_id], references: [id])

  audit_logs    AuditLog[]
  user_devices  UserDevice[]
  notifications Notification[]
  preferences   UserPreferences?

  @@map("users")
}

model Major {
  id            String        @id @default(uuid())
  code          String        @unique
  name          String
  branch_id     String
  branch        Branch        @relation(fields: [branch_id], references: [id])
  created_at    DateTime      @default(now())
  classes       Class[]
  students      Student[]
  subjects      Subject[]
  exams         Exam[]
  grades        Grade[]
  final_grades  FinalGrade[]
  employees     Employee[]
  schedules     Schedule[]
  teaching_logs TeachingLog[]
  applicants    Applicant[]
  question_banks QuestionBank[]

  @@map("majors")
}

model Branch {
  id         String    @id @default(uuid())
  name       String    @unique
  majors     Major[]
  students   Student[]
  created_at DateTime  @default(now())

  @@map("branches")
}

model Batch {
  id            String        @id @default(uuid())
  name          String
  start_date    DateTime
  end_date      DateTime
  is_active     Boolean       @default(true)
  classes       Class[]
  students      Student[]
  grades        Grade[]
  final_grades  FinalGrade[]
  schedules     Schedule[]
  teaching_logs TeachingLog[]

  @@map("batches")
}

model Class {
  id                  String    @id @default(uuid())
  name                String
  grade_level         Int
  major_id            String
  major               Major     @relation(fields: [major_id], references: [id])
  batch_id            String
  batch               Batch     @relation(fields: [batch_id], references: [id])
  homeroom_teacher_id String?
  homeroom_teacher    Employee? @relation(fields: [homeroom_teacher_id], references: [id])
  class_president_id  String?
  class_president     Student?  @relation("ClassPresident", fields: [class_president_id], references: [id])

  students      Student[]
  schedules     Schedule[]
  teaching_logs TeachingLog[]

  @@map("classes")
}

model Student {
  id          String   @id @default(uuid())
  nis         String   @unique
  nik         String   @unique
  full_name   String
  gender      String
  birth_place String
  birth_date  DateTime
  address     String   @db.Text
  phone       String
  email       String   @unique
  status      String   @default("active") // active, alumni, moved

  health_history  String?  @db.Text
  profile_picture String?
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)

  branch_id String
  branch    Branch  @relation(fields: [branch_id], references: [id])
  class_id  String?
  class     Class?  @relation(fields: [class_id], references: [id])
  major_id  String
  major     Major   @relation(fields: [major_id], references: [id])
  batch_id  String
  batch     Batch   @relation(fields: [batch_id], references: [id])

  qr_code    String?  @db.Text
  created_at DateTime @default(now())

  applicant_id String?    @unique
  applicant    Applicant? @relation(fields: [applicant_id], references: [id])

  president_of_classes Class[] @relation("ClassPresident")

  parents      Parent[]
  histories    StudentHistory[]
  user         User?
  attendances  Attendance[]
  sessions     ExamSession[]
  grades       Grade[]
  final_grades FinalGrade[]
  payments     Payment[]
  remedials    Remedial[]
  behavior_assessments StudentBehaviorAssessment[]

  @@map("students")
}

model Parent {
  id          String  @id @default(uuid())
  student_id  String  @unique
  student     Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  father_name String
  mother_name String
  phone       String
  address     String  @db.Text

  @@map("parents")
}

model StudentHistory {
  id          String   @id @default(uuid())
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  type        String // masuk, pindah, keluar
  description String   @db.Text
  date        DateTime

  @@map("student_histories")
}

model Permission {
  id    String           @id @default(uuid())
  name  String           @unique
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role_id       String
  permission_id String
  role          Role       @relation(fields: [role_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  action     String
  module     String
  data       Json
  created_at DateTime @default(now())

  @@map("audit_logs")
}

model UserDevice {
  id        String  @id @default(uuid())
  user_id   String
  user      User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  device_id String
  is_active Boolean @default(true)

  @@map("user_devices")
}

model Employee {
  id        String @id @default(uuid())
  full_name String
  education String

  // Profil Profesional Guru
  education_institution     String?
  education_degree          String?
  education_graduation_year String?
  teaching_specialty        String?

  // Manajemen Masa Kerja
  current_rank     String?
  current_golongan String?

  // Sertifikasi (Dashboard Personalia)
  certification_status String?
  is_certified         Boolean @default(false)

  position  String
  join_date DateTime
  status    String
  major_id  String?
  major     Major?   @relation(fields: [major_id], references: [id])

  user          User?
  documents     EmployeeDocument[]
  attendance    EmployeeAttendance[]
  classes       Class[]
  schedules     Schedule[]
  teaching_logs TeachingLog[]
  behavior_assessments StudentBehaviorAssessment[]

  @@map("employees")
}

model EmployeeDocument {
  id          String   @id @default(uuid())
  employee_id String
  employee    Employee @relation(fields: [employee_id], references: [id])
  file_url    String
  type        String

  @@map("employee_documents")
}

model EmployeeAttendance {
  id          String   @id @default(uuid())
  employee_id String
  employee    Employee @relation(fields: [employee_id], references: [id])
  date        DateTime
  status      String

  @@map("employee_attendance")
}

model Subject {
  id                   String        @id @default(uuid())
  name                 String
  major_id             String?
  major                Major?        @relation(fields: [major_id], references: [id])
  hours_per_week       Int?
  passing_grade        Int           @default(75)
  competency_standards String?       @db.Text
  schedules            Schedule[]
  exams                Exam[]
  grades               Grade[]
  final_grades         FinalGrade[]
  teaching_logs        TeachingLog[]
  remedials            Remedial[]
  question_banks       QuestionBank[]

  @@map("subjects")
}

model Schedule {
  id          String       @id @default(uuid())
  class_id    String?
  class       Class?       @relation(fields: [class_id], references: [id])
  major_id    String
  major       Major        @relation(fields: [major_id], references: [id])
  batch_id    String
  batch       Batch        @relation(fields: [batch_id], references: [id])
  subject_id  String
  subject     Subject      @relation(fields: [subject_id], references: [id])
  teacher_id  String
  teacher     Employee     @relation(fields: [teacher_id], references: [id])
  room        String?
  day         String
  start_time  String
  end_time    String
  attendances Attendance[]

  @@map("schedules")
}

model Attendance {
  id          String   @id @default(uuid())
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  schedule_id String
  schedule    Schedule @relation(fields: [schedule_id], references: [id])
  date        DateTime
  status      String

  @@map("attendances")
}

model TeachingLog {
  id               String   @id @default(uuid())
  teacher_id       String
  teacher          Employee @relation(fields: [teacher_id], references: [id])
  class_id         String?
  class            Class?   @relation(fields: [class_id], references: [id])
  major_id         String
  major            Major    @relation(fields: [major_id], references: [id])
  batch_id         String
  batch            Batch    @relation(fields: [batch_id], references: [id])
  subject_id       String
  subject          Subject  @relation(fields: [subject_id], references: [id])
  note             String   @db.Text
  material_summary String?  @db.Text
  assignment_given String?  @db.Text
  date             DateTime

  @@map("teaching_logs")
}

model AcademicCalendar {
  id    String   @id @default(uuid())
  title String
  date  DateTime
  type  String

  @@map("academic_calendar")
}

model Exam {
  id         String   @id @default(uuid())
  title      String
  subject_id String
  subject    Subject  @relation(fields: [subject_id], references: [id])
  major_id   String
  major      Major    @relation(fields: [major_id], references: [id])
  duration   Int // in minutes
  token      String
  start_time DateTime
  end_time   DateTime

  questions Question[]
  sessions  ExamSession[]
  grades    Grade[]
  remedials Remedial[]

  @@map("exams")
}

model Question {
  id            String           @id @default(uuid())
  exam_id       String
  exam          Exam             @relation(fields: [exam_id], references: [id])
  type          String // mcq, essay
  question_text String           @db.Text
  difficulty    String
  options       QuestionOption[]
  answers       StudentAnswer[]

  @@map("questions")
}

model QuestionOption {
  id          String   @id @default(uuid())
  question_id String
  question    Question @relation(fields: [question_id], references: [id])
  option_text String   @db.Text
  is_correct  Boolean

  @@map("question_options")
}

model QuestionBank {
  id            String           @id @default(uuid())
  title         String
  subject_id    String
  subject       Subject          @relation(fields: [subject_id], references: [id])
  major_id      String
  major         Major            @relation(fields: [major_id], references: [id])
  type          String // mcq, essay
  question_text String           @db.Text
  difficulty    String
  options       QuestionBankOption[]
  created_at    DateTime         @default(now())

  @@map("question_banks")
}

model QuestionBankOption {
  id              String       @id @default(uuid())
  question_bank_id String
  question_bank   QuestionBank @relation(fields: [question_bank_id], references: [id], onDelete: Cascade)
  option_text     String       @db.Text
  is_correct      Boolean

  @@map("question_bank_options")
}

model ExamSession {
  id            String          @id @default(uuid())
  exam_id       String
  exam          Exam            @relation(fields: [exam_id], references: [id])
  student_id    String?
  student       Student?        @relation(fields: [student_id], references: [id], onDelete: Cascade)
  applicant_id  String?
  applicant     Applicant?      @relation(fields: [applicant_id], references: [id], onDelete: Cascade)
  start_time    DateTime        @default(now())
  end_time      DateTime?
  status        String // ongoing, submitted, blocked
  device_id     String?
  warning_count Int             @default(0)
  answers       StudentAnswer[]
  logs          ExamLog[]

  @@map("exam_sessions")
}

model StudentAnswer {
  id          String      @id @default(uuid())
  session_id  String
  session     ExamSession @relation(fields: [session_id], references: [id])
  question_id String
  question    Question    @relation(fields: [question_id], references: [id])
  answer      String      @db.Text
  score       Decimal?    @db.Decimal(5, 2)

  @@unique([session_id, question_id])
  @@map("student_answers")
}

model ExamLog {
  id          String      @id @default(uuid())
  session_id  String
  session     ExamSession @relation(fields: [session_id], references: [id])
  type        String // tab_switch, window_blur, exit_fullscreen, warning, violation
  description String?     @db.Text
  timestamp   DateTime    @default(now())

  @@map("exam_logs")
}

model Grade {
  id           String     @id @default(uuid())
  student_id   String?
  student      Student?   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  applicant_id String?
  applicant    Applicant? @relation(fields: [applicant_id], references: [id], onDelete: Cascade)
  subject_id   String
  subject      Subject    @relation(fields: [subject_id], references: [id])
  type         String // assignment, uts, uas, cbt
  score        Decimal    @db.Decimal(5, 2)
  weight       Decimal    @db.Decimal(5, 2)
  exam_id      String?
  exam         Exam?      @relation(fields: [exam_id], references: [id])
  batch_id     String
  batch        Batch      @relation(fields: [batch_id], references: [id])
  major_id     String
  major        Major      @relation(fields: [major_id], references: [id])
  created_at   DateTime   @default(now())

  @@map("grades")
}

model GradeComponent {
  id                String  @id @default(uuid())
  name              String  @unique // Tugas, UTS, UAS, CBT
  weight_percentage Decimal @db.Decimal(5, 2)

  @@map("grade_components")
}

model FinalGrade {
  id                    String  @id @default(uuid())
  student_id            String
  student               Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject_id            String
  subject               Subject @relation(fields: [subject_id], references: [id])
  final_score           Decimal @db.Decimal(5, 2)
  grade_letter          String
  is_passed             Boolean
  description           String? @db.Text
  competencies_achieved String? @db.Text
  semester              Int
  batch_id              String
  batch                 Batch   @relation(fields: [batch_id], references: [id])
  major_id              String
  major                 Major   @relation(fields: [major_id], references: [id])

  @@map("final_grades")
}

model Remedial {
  id           String    @id @default(uuid())
  student_id   String
  student      Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject_id   String
  subject      Subject   @relation(fields: [subject_id], references: [id])
  exam_id      String?
  exam         Exam?     @relation(fields: [exam_id], references: [id])
  status       String    @default("pending") // pending, scheduled, completed
  score_before Decimal   @db.Decimal(5, 2)
  score_after  Decimal?  @db.Decimal(5, 2)
  scheduled_at DateTime?
  completed_at DateTime?
  notes        String?   @db.Text
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("remedials")
}

model Applicant {
  id              String   @id @default(uuid())
  full_name       String
  nik             String?  @unique
  email           String   @unique
  phone           String
  gender          String
  birth_place     String
  birth_date      DateTime
  address         String   @db.Text
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  marital_status  String   @default("single")
  education_level String   @default("SLTA")
  father_name     String?
  mother_name     String?
  previous_school String
  document_url    String?  @db.Text // Ijazah
  ktp_url         String?  @db.Text
  kk_url          String?  @db.Text
  sktm_url        String?  @db.Text
  vaccine_url     String?  @db.Text
  health_cert_url String?  @db.Text
  major_id        String
  major           Major    @relation(fields: [major_id], references: [id])
  status          String   @default("pending") // pending, verified, accepted, rejected
  created_at      DateTime @default(now())

  exam_sessions ExamSession[]
  student       Student?
  grades        Grade[]

  @@map("applicants")
}

model Fee {
  id          String    @id @default(uuid())
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  type        String // monthly, once, other
  description String?   @db.Text
  payments    Payment[]

  @@map("fees")
}

model Payment {
  id         String   @id @default(uuid())
  student_id String
  student    Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  fee_id     String
  fee        Fee      @relation(fields: [fee_id], references: [id])
  amount     Decimal  @db.Decimal(12, 2)
  method     String // cash, transfer, gateway
  status     String   @default("pending") // pending, success, failed
  date       DateTime @default(now())

  @@map("payments")
}

model Asset {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  category   String
  location   String
  condition  String // good, fair, broken
  status     String   @default("available") // available, loaned, maintenance
  qr_code    String?  @db.LongText
  created_at DateTime @default(now())

  @@map("assets")
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String?
  user       User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title      String
  message    String   @db.Text
  type       String // payment, exam, announcement, attendance, ppdb
  is_read    Boolean  @default(false)
  link       String? // Optional link terkait notifikasi
  created_at DateTime @default(now())

  @@map("notifications")
}

model UserPreferences {
  id           String   @id @default(uuid())
  user_id      String   @unique
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Notification preferences
  notif_academic   Boolean @default(true)
  notif_messages   Boolean @default(true)
  notif_payments   Boolean @default(true)
  notif_email_digest Boolean @default(false)

  // System settings (for admin/teacher)
  active_academic_year String?
  active_semester      Int?
  cbt_strict_anticheat Boolean @default(true)
  cbt_show_score_auto  Boolean @default(false)
  cbt_random_questions Boolean @default(true)
  cbt_device_locking   Boolean @default(true)
  maintenance_mode     Boolean @default(false)

  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  @@map("user_preferences")
}

model StudentBehaviorAssessment {
  id           String   @id @default(uuid())
  student_id   String
  student      Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  assessor_id  String
  assessor     Employee @relation(fields: [assessor_id], references: [id])
  date         DateTime
  attitude     Int
  ethics       Int
  manners      Int
  overallScore Decimal  @db.Decimal(5, 2)
  notes        String?  @db.Text
  created_at   DateTime @default(now())

  @@map("student_behavior_assessments")
}
